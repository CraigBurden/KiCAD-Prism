kicad-prism.pixxel.space {
    tls internal

    reverse_proxy /.well-known/kicad-remote-provider host.docker.internal:8000
    reverse_proxy /api/* host.docker.internal:8000
    reverse_proxy /oauth/* host.docker.internal:8000
    reverse_proxy /remote-provider/* host.docker.internal:8000

    reverse_proxy host.docker.internal:8080
}
